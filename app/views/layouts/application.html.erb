<!doctype html>
<html lang="<%= I18n.locale %>" class="h-full bg-bg">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="dark">
  <title><%= t(:app_name) %></title>
  <%= favicon_link_tag 'favicon.png', rel: 'icon', type: 'image/png' %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application" %>
  <%= javascript_importmap_tags %>
</head>
<body class="min-h-full bg-bg text-text font-sans antialiased">
  <div class="min-h-dvh flex flex-col">
    <header class="border-b border-border">
      <div class="max-w-6xl mx-auto px-6 py-5">
        <%= render "shared/header" %>
      </div>
    </header>

    <main class="flex-1 w-full max-w-6xl mx-auto px-6 py-10">
      <% if notice %>
        <%= render "shared/notice" %>
      <% end %>
      <% if alert %>
        <%= render "shared/alert" %>
      <% end %>
      <%= yield %>
    </main>

    <footer class="border-t border-border mt-12">
      <div class="max-w-6xl mx-auto px-6 py-6">
        <%= render "shared/footer" %>
      </div>
    </footer>
  </div>
</body>
</html>
