<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title><%= t(:app_name) %></title>
  </head>
  <body style="margin:0; padding:0; background:#fafafa;
               font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui,
                            Roboto, 'Helvetica Neue', Arial, sans-serif;
               color: #0a0a0a; line-height: 1.5;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
           style="background:#fafafa;">
      <tr>
        <td align="center" style="padding: 32px 16px;">
          <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0"
                 style="max-width:600px; width:100%; background:#ffffff; border:1px solid #e5e5e5;
                        border-radius:10px; overflow:hidden;">
            <tr>
              <td style="padding: 24px 32px; border-bottom: 1px solid #e5e5e5;">
                <span style="display:inline-block; width:10px; height:10px;
                             background:#C7F36A; vertical-align:middle; margin-right:8px;"></span>
                <span style="font-family: ui-monospace, 'SF Mono', Menlo, monospace;
                             font-size: 14px; color: #0a0a0a; vertical-align:middle;">
                  <%= t(:app_name).downcase %>.
                </span>
              </td>
            </tr>
            <tr>
              <td style="padding: 32px;">
                <%= yield %>
              </td>
            </tr>
            <tr>
              <td style="padding: 16px 32px; background:#fafafa; border-top:1px solid #e5e5e5;
                         font-size: 12px; color: #6b6b6b;">
                <%= Time.current.strftime("%-d. %-m. %Y %H:%M") %>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
