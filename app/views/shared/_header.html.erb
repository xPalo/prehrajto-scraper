<div class="flex items-center justify-between gap-6 flex-wrap">
  <%= link_to root_path, class: "flex items-center gap-2.5 group" do %>
    <span class="w-2.5 h-2.5 bg-accent block" aria-hidden="true"></span>
    <span class="font-mono text-lg text-text group-hover:text-accent transition-colors lowercase tracking-tight">
      <%= t(:app_name) %><span class="text-accent">.</span>
    </span>
  <% end %>

  <nav class="flex items-center gap-6 text-sm flex-wrap" aria-label="Primary">
    <%= link_to t(:home), root_path,
        class: "nav-link #{current_class?(root_path)}" %>

    <% if user_signed_in? %>
      <%= link_to t(:'header.favourites'), favs_path,
          class: "nav-link #{current_class?(favs_path)}" %>
      <%= link_to t(:'header.watchdogs'), watchdogs_path,
          class: "nav-link #{current_class?(watchdogs_path)}" %>
      <%= link_to t(:'header.videos'), videos_path,
          class: "nav-link #{current_class?(videos_path)}" %>
    <% end %>
  </nav>

  <div class="flex items-center gap-3 text-sm">
    <% if user_signed_in? %>
      <%= link_to edit_user_registration_path,
          class: "text-text-dim hover:text-text transition-colors flex items-center gap-1.5 lowercase",
          title: t(:'header.edit_profile') do %>
        <%= render "shared/icon", name: "user", css: "w-4 h-4" %>
        <span class="hidden sm:inline"><%= current_user.email.split("@").first %></span>
      <% end %>
      <%= button_to destroy_user_session_path, method: :delete,
          class: "text-text-dim hover:text-danger transition-colors flex items-center gap-1.5 bg-transparent border-0 p-0 cursor-pointer lowercase",
          title: t(:'header.log_out') do %>
        <%= render "shared/icon", name: "log-out", css: "w-4 h-4" %>
      <% end %>
    <% else %>
      <%= link_to t(:'header.log_in'), new_user_session_path,
          class: "nav-link" %>
      <%= link_to t(:'header.sign_up'), new_user_registration_path,
          class: "btn-primary" %>
    <% end %>
  </div>
</div>
