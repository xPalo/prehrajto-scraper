<div class="panel p-6 mb-6">
  <h2 class="text-2xl font-medium tracking-tight mb-2"><%= title %></h2>
  <div class="text-sm text-text-dim font-mono mb-5">
    <%= duration %> <span class="text-text-mute mx-1">·</span> <%= size %>
  </div>
  <div class="rounded overflow-hidden bg-black">
    <video class="w-full block aspect-video" controls preload="metadata">
      <source src="<%= link %>" type="video/mp4">
      Your browser does not support HTML video.
    </video>
  </div>
</div>
