<div class="flex items-center justify-between flex-wrap gap-4 text-xs text-text-mute font-mono">
  <div>
    © <%= Time.current.year %> <%= t(:app_name).downcase %>
  </div>

  <div class="flex items-center gap-1">
    <%= link_to "sk", change_locale_path("sk"),
        class: "px-2 py-1 rounded hover:text-text hover:bg-surface-2 transition-colors lowercase
                #{'text-accent' if I18n.locale == :sk}" %>
    <span class="text-text-mute/40">·</span>
    <%= link_to "en", change_locale_path("en"),
        class: "px-2 py-1 rounded hover:text-text hover:bg-surface-2 transition-colors lowercase
                #{'text-accent' if I18n.locale == :en}" %>
  </div>
</div>
