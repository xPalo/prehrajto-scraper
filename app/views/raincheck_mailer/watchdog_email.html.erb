<% if @sorted_flights.empty? %>
  <p style="margin:0; font-size:14px; color:#52525b;">Žiadne lety neboli nájdené.</p>
<% else %>
  <% min_price = @sorted_flights.first["price"].to_f %>

  <h2 style="margin:0 0 8px 0; font-size:22px; font-weight:600; letter-spacing:-0.01em;
             color:#0a0a0a;">
    Najlacnejšie nájdené lety
  </h2>
  <p style="margin:0 0 24px 0; font-size:13px; color:#52525b;">
    <%= @sorted_flights.size %> letov · najnižšia cena
    <strong style="color:#0a0a0a;">€<%= '%.2f' % min_price %></strong>
  </p>

  <table role="presentation" cellspacing="0" cellpadding="0" border="0"
         style="border-collapse:collapse; width:100%; font-size:13px;">
    <thead>
      <tr style="background:#fafafa;">
        <th style="text-align:left; padding:10px 12px; border-bottom:1px solid #e5e5e5;
                   font-family: ui-monospace,'SF Mono',Menlo,monospace;
                   font-weight:600; font-size:11px; text-transform:uppercase;
                   letter-spacing:0.1em; color:#52525b;">Odlet</th>
        <th style="text-align:left; padding:10px 12px; border-bottom:1px solid #e5e5e5;
                   font-family: ui-monospace,'SF Mono',Menlo,monospace;
                   font-weight:600; font-size:11px; text-transform:uppercase;
                   letter-spacing:0.1em; color:#52525b;">Trasa</th>
        <th style="text-align:left; padding:10px 12px; border-bottom:1px solid #e5e5e5;
                   font-family: ui-monospace,'SF Mono',Menlo,monospace;
                   font-weight:600; font-size:11px; text-transform:uppercase;
                   letter-spacing:0.1em; color:#52525b;">Aerolinka</th>
        <th style="text-align:right; padding:10px 12px; border-bottom:1px solid #e5e5e5;
                   font-family: ui-monospace,'SF Mono',Menlo,monospace;
                   font-weight:600; font-size:11px; text-transform:uppercase;
                   letter-spacing:0.1em; color:#52525b;">Cena</th>
      </tr>
    </thead>
    <tbody>
      <% @sorted_flights.each do |f| %>
        <% departure = DateTime.parse(f["departure"]).strftime("%-d. %-m. %Y %H:%M") %>
        <% price = f["price"].to_f %>
        <% airline = f["airline"] || "?" %>
        <% is_min = price == min_price %>
        <tr>
          <td style="padding:10px 12px; border-bottom:1px solid #f0f0f0;
                     font-family: ui-monospace,'SF Mono',Menlo,monospace;
                     <%= 'background:#f6ffd9;' if is_min %>">
            <%= departure %>
          </td>
          <td style="padding:10px 12px; border-bottom:1px solid #f0f0f0;
                     font-family: ui-monospace,'SF Mono',Menlo,monospace;
                     <%= 'background:#f6ffd9;' if is_min %>">
            <%= f["origin"] %> → <%= f["destination"] %>
          </td>
          <td style="padding:10px 12px; border-bottom:1px solid #f0f0f0;
                     <%= 'background:#f6ffd9;' if is_min %>">
            <%= airline %>
          </td>
          <td style="padding:10px 12px; border-bottom:1px solid #f0f0f0;
                     text-align:right; font-weight:600;
                     font-family: ui-monospace,'SF Mono',Menlo,monospace;
                     <%= 'background:#f6ffd9;' if is_min %>
                     <%= is_min ? 'color:#3a7900;' : 'color:#0a0a0a;' %>">
            €<%= '%.2f' % price %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
