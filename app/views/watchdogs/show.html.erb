<% destination = @watchdog.to_airport.presence || @watchdog.to_country %>

<div class="flex items-start justify-between gap-4 mb-8 flex-wrap">
  <div>
    <div class="text-xs text-text-mute font-mono uppercase tracking-wider mb-2">
      <%= t(:'watchdog.show') %>
    </div>
    <h1 class="text-3xl sm:text-4xl font-medium tracking-tight font-mono">
      <%= @watchdog.from_airport %>
      <span class="text-text-mute mx-2">→</span>
      <%= destination %>
    </h1>
  </div>
  <span class="<%= @watchdog.is_active? ? 'badge-ok' : 'badge-mute' %> mt-3">
    <span class="dot <%= @watchdog.is_active? ? 'bg-ok' : 'bg-text-mute' %>"></span>
    <%= @watchdog.is_active? ? t('watchdog.active') : t('watchdog.inactive') %>
  </span>
</div>

<div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-border rounded overflow-hidden mb-8">
  <div class="bg-surface p-4">
    <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
      <%= t('watchdog.date_watch_from') %>
    </div>
    <div class="font-mono text-sm sm:text-base text-text">
      <%= l(@watchdog.date_watch_from) %>
    </div>
  </div>
  <div class="bg-surface p-4">
    <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
      <%= t('watchdog.date_watch_to') %>
    </div>
    <div class="font-mono text-sm sm:text-base text-text">
      <%= l(@watchdog.date_watch_to) %>
    </div>
  </div>
  <div class="bg-surface p-4">
    <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
      <%= t('watchdog.max_price') %>
    </div>
    <div class="font-mono text-sm sm:text-base text-text">
      <% if @watchdog.max_price.present? %>
        <%= number_to_currency(@watchdog.max_price, unit: "€", precision: 0) %>
      <% else %>
        <span class="text-text-mute">—</span>
      <% end %>
    </div>
  </div>
  <div class="bg-surface p-4">
    <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
      <%= t('watchdog.status') %>
    </div>
    <div class="font-mono text-sm sm:text-base">
      <span class="<%= @watchdog.is_active? ? 'text-accent' : 'text-text-mute' %>">
        <%= @watchdog.is_active? ? t('watchdog.active') : t('watchdog.inactive') %>
      </span>
    </div>
  </div>
</div>

<% if @watchdog.can_analyze_price? && @watchdog.price_history.present? %>
  <% min_price    = @watchdog.price_history.map { |p| p["y"] }.min %>
  <% max_price    = @watchdog.price_history.map { |p| p["y"] }.max %>
  <% sorted       = @watchdog.price_history.sort_by { |p| p["x"] } %>
  <% latest_price = sorted.last["y"] %>

  <div class="panel p-5 sm:p-6 mb-6"
       data-controller="chart"
       data-chart-data-value="<%= @watchdog.price_history.to_json %>"
       data-chart-label-value="<%= t('watchdog.price_development') %>"
       data-chart-x-label-value="<%= t('watchdog.date') %>"
       data-chart-y-label-value="<%= t('watchdog.price') %>">
    <div class="eyebrow eyebrow-left mb-5">
      <span><%= t('watchdog.price_development') %></span>
    </div>
    <div class="chart-wrap">
      <canvas data-chart-target="canvas"></canvas>
    </div>
  </div>

  <div class="grid grid-cols-3 gap-px bg-border rounded overflow-hidden mb-8">
    <div class="bg-surface p-4">
      <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
        <%= t('watchdog.lowest_recorded_price') %>
      </div>
      <div class="font-mono text-base text-accent">
        <%= number_to_currency(min_price, unit: "€", precision: 2) %>
      </div>
    </div>
    <div class="bg-surface p-4">
      <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
        <%= t('watchdog.latest_recorded_price') %>
      </div>
      <div class="font-mono text-base text-text">
        <%= number_to_currency(latest_price, unit: "€", precision: 2) %>
      </div>
    </div>
    <div class="bg-surface p-4">
      <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
        max
      </div>
      <div class="font-mono text-base text-text-dim">
        <%= number_to_currency(max_price, unit: "€", precision: 2) %>
      </div>
    </div>
  </div>
<% else %>
  <div class="panel p-10 text-center mb-8">
    <div class="text-text-mute font-mono text-sm"><%= t('watchdog.no_data_yet') %></div>
  </div>
<% end %>

<div class="flex items-center gap-2">
  <%= link_to watchdogs_path, class: "btn-ghost" do %>
    <%= render "shared/icon", name: "arrow-left", css: "w-4 h-4" %>
    <%= t(:back) %>
  <% end %>
  <%= link_to edit_watchdog_path(@watchdog), class: "btn-ghost" do %>
    <%= render "shared/icon", name: "settings", css: "w-4 h-4" %>
    <%= t(:edit) %>
  <% end %>
</div>
