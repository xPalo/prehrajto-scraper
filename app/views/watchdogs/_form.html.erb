<div class="max-w-xl mx-auto" data-controller="airport-select">
  <%= form_with(model: watchdog, local: true) do |form| %>
    <% if watchdog.errors.any? %>
      <div class="flash flash-alert mb-6">
        <div class="flex-1">
          <div class="font-medium mb-1">
            <%= pluralize(watchdog.errors.count, t(:error, default: 'error')) %>:
          </div>
          <ul class="text-sm space-y-0.5">
            <% watchdog.errors.full_messages.each do |message| %>
              <li>— <%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <div class="space-y-5">
      <div>
        <%= form.label :from_airport, class: "label" do %>
          <%= t(:'watchdog.from_airport') %>
          <span class="text-danger">*</span>
        <% end %>
        <%= form.select :from_airport, @airports, { include_blank: true },
              required: true,
              id: "from_airport",
              data: { "airport-select-target": "from" } %>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <%= form.label :date_watch_from, class: "label" do %>
            <%= t(:'watchdog.date_watch_from') %>
            <span class="text-danger">*</span>
          <% end %>
          <%= form.date_field :date_watch_from, class: "input font-mono", required: true %>
        </div>
        <div>
          <%= form.label :date_watch_to, class: "label" do %>
            <%= t(:'watchdog.date_watch_to') %>
            <span class="text-danger">*</span>
          <% end %>
          <%= form.date_field :date_watch_to, class: "input font-mono", required: true %>
        </div>
      </div>

      <div id="to_airport_wrapper" data-airport-select-target="toWrapper">
        <%= form.label :to_airport, t(:'watchdog.to_airport'), class: "label" %>
        <%= form.select :to_airport, @airports, { include_blank: true },
              id: "to_airport",
              data: { "airport-select-target": "to" } %>
      </div>

      <div id="to_country_wrapper" data-airport-select-target="countryWrapper">
        <%= form.label :to_country, t(:'watchdog.to_country'), class: "label" %>
        <%= form.text_field :to_country, class: "input",
              id: "to_country",
              placeholder: "Austria",
              data: { "airport-select-target": "country" } %>
      </div>

      <div>
        <%= form.label :max_price, t(:'watchdog.max_price'), class: "label" %>
        <%= form.number_field :max_price, class: "input font-mono", placeholder: "100" %>
      </div>

      <label class="flex items-center gap-3 cursor-pointer select-none">
        <span class="relative inline-block">
          <%= form.check_box :is_active, class: "peer sr-only" %>
          <span class="block w-10 h-6 bg-surface-2 border border-border rounded-full transition-colors
                       peer-checked:bg-accent peer-checked:border-accent"></span>
          <span class="absolute left-1 top-1 w-4 h-4 bg-text-mute rounded-full transition-transform
                       peer-checked:translate-x-4 peer-checked:bg-accent-ink"></span>
        </span>
        <span class="text-sm text-text"><%= t(:'watchdog.is_active') %></span>
      </label>
    </div>

    <%= form.hidden_field :user_id, value: current_user.id %>

    <div class="mt-8 flex items-center gap-2 flex-wrap">
      <%= form.submit t('save'), class: "btn-primary cursor-pointer" %>
      <%= link_to t('back'), :back, class: "btn-ghost" %>
      <% if watchdog.persisted? %>
        <span class="flex-1"></span>
        <%= button_to t('delete'), watchdog_path(watchdog),
              method: :delete,
              form: { data: { turbo_confirm: t('delete_confirm') } },
              data: { confirm: t('delete_confirm') },
              class: "btn-danger" %>
      <% end %>
    </div>
  <% end %>
</div>
