<section class="mb-12" data-controller="search">
  <h1 class="text-4xl sm:text-5xl font-medium tracking-tight mb-2 text-balance">
    <%= t(:app_name) %><span class="text-accent">.</span>
  </h1>
  <p class="text-text-dim mb-8 text-sm font-mono lowercase tracking-wider">
    <%= t(:search_input) %>
  </p>

  <div class="flex items-stretch gap-2 max-w-2xl">
    <div class="relative flex-1">
      <span class="absolute left-4 top-1/2 -translate-y-1/2 text-text-mute pointer-events-none">
        <%= render "shared/icon", name: "search", css: "w-5 h-5" %>
      </span>
      <input type="text"
             data-search-target="input"
             data-action="keydown->search#keydown"
             value="<%= params[:search_url] %>"
             autocomplete="off"
             autofocus
             class="input-lg pl-12 font-mono caret-accent"
             placeholder="<%= t(:search_input) %>"
             aria-label="<%= t(:search_input) %>">
    </div>
    <button type="button"
            data-action="search#submit"
            class="btn-primary px-5">
      <%= render "shared/icon", name: "arrow-right", css: "w-5 h-5" %>
    </button>
  </div>
</section>

<% if @divs.present? && !params[:movie_url] %>
  <section class="mb-8">
    <div class="flex items-center justify-between gap-3 mb-4 flex-wrap">
      <div class="eyebrow eyebrow-left">
        <span><%= pluralize(@divs.length, 'result') %></span>
      </div>

      <%= form_with url: root_path, method: :get, local: true,
                    data: { controller: "order", action: "change->order#change" },
                    class: "flex items-center gap-2" do |f| %>
        <%= f.hidden_field :search_url, value: params[:search_url] %>
        <label class="text-xs text-text-dim font-mono uppercase tracking-wider"
               for="order-select"><%= t(:'order.order_by') %></label>
        <select id="order-select"
                name="order"
                class="input py-1.5 pr-8 text-sm w-auto"
                aria-label="<%= t(:'order.order_by') %>">
          <option value="" <%= 'selected' if params[:order].blank? %>>—</option>
          <option value="title_asc"     <%= 'selected' if params[:order] == 'title_asc' %>><%= t(:'order.title_asc') %></option>
          <option value="title_desc"    <%= 'selected' if params[:order] == 'title_desc' %>><%= t(:'order.title_desc') %></option>
          <option value="size_asc"      <%= 'selected' if params[:order] == 'size_asc' %>><%= t(:'order.size_asc') %></option>
          <option value="size_desc"     <%= 'selected' if params[:order] == 'size_desc' %>><%= t(:'order.size_desc') %></option>
          <option value="duration_asc"  <%= 'selected' if params[:order] == 'duration_asc' %>><%= t(:'order.duration_asc') %></option>
          <option value="duration_desc" <%= 'selected' if params[:order] == 'duration_desc' %>><%= t(:'order.duration_desc') %></option>
        </select>
      <% end %>
    </div>

    <%= render "results_list", divs: @divs %>
  </section>
<% end %>

<% if @no_results %>
  <div class="panel p-10 text-center">
    <div class="text-text-mute font-mono text-sm"><%= t(:no_results) %></div>
  </div>
<% end %>

<% if params[:movie_url].present? && @video_src %>
  <section>
    <%= render "shared/movie",
        title: params[:movie_title],
        link: @video_src,
        duration: params[:movie_duration],
        size: params[:movie_size] %>

    <% if user_signed_in? %>
      <div class="flex flex-wrap items-center gap-2">
        <%= link_to new_fav_path(
              title: params[:movie_title].to_s.gsub('.', ' ').strip,
              movie_url: params[:movie_url],
              duration: params[:movie_duration],
              size: params[:movie_size],
              user_id: current_user.id,
              image_src: params[:image_src]
            ), class: "btn-primary" do %>
          <%= render "shared/icon", name: "plus", css: "w-4 h-4" %>
          <%= t(:'fav.new') %>
        <% end %>
        <%= link_to root_path(search_url: params[:search_url]), class: "btn-ghost" do %>
          <%= render "shared/icon", name: "arrow-left", css: "w-4 h-4" %>
          <%= t(:back) %>
        <% end %>
      </div>
    <% end %>

    <div class="mt-10"
         data-controller="lazy-load"
         data-lazy-load-src-value="<%= similar_path(q: params[:search_url], title: params[:movie_title], exclude: params[:movie_url]) %>">
      <div class="text-text-mute font-mono text-sm">
        <%= t(:'similar.loading') %>
      </div>
    </div>
  </section>
<% end %>
