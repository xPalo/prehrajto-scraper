<div style="font-family: sans-serif; padding: 20px;">
  <h2 style="color: #c0392b;">Flight fetcher failure</h2>

  <table style="border-collapse: collapse; background: #f9f9f9; border-radius: 8px; overflow: hidden;">
    <tr>
      <td style="padding: 8px 12px; font-weight: bold;">Provider</td>
      <td style="padding: 8px 12px;"><%= @provider %></td>
    </tr>
    <tr>
      <td style="padding: 8px 12px; font-weight: bold;">Error type</td>
      <td style="padding: 8px 12px;"><%= @error_type %></td>
    </tr>
    <tr>
      <td style="padding: 8px 12px; font-weight: bold;">Host</td>
      <td style="padding: 8px 12px;"><%= @host %></td>
    </tr>
    <tr>
      <td style="padding: 8px 12px; font-weight: bold;">Time</td>
      <td style="padding: 8px 12px;"><%= Time.current.strftime("%Y-%m-%d %H:%M:%S %Z") %></td>
    </tr>
  </table>

  <pre style="background: #f5f5f5; padding: 12px; margin-top: 16px; white-space: pre-wrap; word-break: break-word; border-radius: 4px;"><%= @message %></pre>

  <p style="font-size: 0.9em; color: #7f8c8d; margin-top: 16px;">
    Further alerts for this provider and error type are suppressed for 1 hour.
  </p>
</div>
