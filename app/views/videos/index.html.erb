<div class="flex items-end justify-between flex-wrap gap-4 mb-8">
  <div>
    <h1 class="text-3xl font-medium tracking-tight"><%= t(:'video.index') %></h1>
    <% if @videos.any? %>
      <p class="text-text-mute font-mono text-xs mt-1 tracking-wider uppercase">
        <%= pluralize(@videos.size, 'video') %>
      </p>
    <% end %>
  </div>

  <%= link_to new_video_path, class: "btn-primary" do %>
    <%= render "shared/icon", name: "plus", css: "w-4 h-4" %>
    <%= t(:'video.new') %>
  <% end %>
</div>

<% if @videos.any? %>
  <ul class="panel divide-y divide-border">
    <% @videos.each do |video| %>
      <li class="flex items-center gap-4 p-4 hover:bg-surface-2 transition-colors">
        <span class="badge <%= video_status_badge_class(video.status) %> shrink-0">
          <%= t("video.status_#{video.status}") %>
        </span>

        <div class="flex-1 min-w-0">
          <%= link_to video_path(video),
              class: "block font-mono text-sm sm:text-base font-medium text-text hover:text-accent transition-colors truncate" do %>
            <%= video.original_filename %>
          <% end %>
          <div class="text-xs text-text-mute mt-1 font-mono flex flex-wrap items-center gap-x-3 gap-y-1">
            <% if video.file_size %>
              <span><%= number_to_human_size(video.file_size) %></span>
            <% end %>
            <% if video.duration.present? && video.duration > 0 %>
              <span class="text-text-mute/40">·</span>
              <span><%= Time.at(video.duration).utc.strftime("%H:%M:%S") %></span>
            <% end %>
            <% if video.recorded_at.present? %>
              <span class="text-text-mute/40">·</span>
              <span><%= video.recorded_at.strftime("%-d. %-m. %Y") %></span>
            <% end %>
          </div>
        </div>

        <div class="flex items-center gap-1 shrink-0">
          <%= link_to video_path(video), class: "btn-icon", title: t(:show) do %>
            <%= render "shared/icon", name: "eye", css: "w-4 h-4" %>
          <% end %>
          <% if video.completed? %>
            <%= link_to download_video_path(video), class: "btn-icon hover:text-accent hover:border-accent/60", title: t(:'video.download') do %>
              <%= render "shared/icon", name: "download", css: "w-4 h-4" %>
            <% end %>
          <% end %>
          <%= button_to video_path(video), method: :delete,
                form: { data: { turbo_confirm: t(:delete_confirm) } },
                data: { confirm: t(:delete_confirm) },
                class: "btn-icon hover:text-danger hover:border-danger/60",
                title: t(:delete) do %>
            <%= render "shared/icon", name: "trash", css: "w-4 h-4" %>
          <% end %>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="panel p-12 text-center">
    <div class="text-text-mute font-mono text-sm mb-4">
      <%= t(:'video.empty_state', default: t(:'video.new')) %>
    </div>
    <%= link_to new_video_path, class: "btn-primary inline-flex" do %>
      <%= render "shared/icon", name: "plus", css: "w-4 h-4" %>
      <%= t(:'video.new') %>
    <% end %>
  </div>
<% end %>
