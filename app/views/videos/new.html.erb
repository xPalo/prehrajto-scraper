<div class="max-w-xl mx-auto"
     data-controller="video-upload"
     data-video-upload-uploading-value="<%= t('video.uploading') %>"
     data-video-upload-success-value="<%= t('video.created') %>"
     data-video-upload-failure-value="<%= t('video.upload_failed') %>"
     data-video-upload-fallback-url-value="<%= videos_path %>">

  <h1 class="text-3xl font-medium tracking-tight mb-8 text-center">
    <%= t(:'video.new') %>
  </h1>

  <%= form_with(url: videos_path, multipart: true, id: 'video-upload-form',
                data: { "video-upload-target": "form" }) do |form| %>

    <label class="block panel-inset p-6 mb-5 text-center cursor-pointer
                  border-dashed hover:border-accent/60 hover:bg-surface-2 transition-colors">
      <%= render "shared/icon", name: "film", css: "w-8 h-8 mx-auto mb-3 text-text-mute" %>
      <div class="text-sm text-text mb-1"><%= t('video.select_files') %></div>
      <div class="text-xs text-text-mute font-mono"><%= t('video.max_file_size', size: '500MB') %></div>
      <%= file_field_tag 'original_videos[]',
            multiple: true,
            accept: "video/*",
            required: true,
            class: "sr-only",
            id: "video_file_input",
            data: { "video-upload-target": "file" } %>
      <%= hidden_field_tag 'recorded_ats', '',
            id: 'video_recorded_ats',
            data: { "video-upload-target": "recordedAt" } %>
    </label>

    <div class="hidden mb-5"
         data-video-upload-target="progress">
      <div class="text-xs text-text-dim font-mono mb-2 text-center"
           data-video-upload-target="status"></div>
      <div class="h-2 bg-surface-2 rounded overflow-hidden">
        <div class="h-full w-0 bg-accent transition-all duration-200"
             data-video-upload-target="bar"
             style="width:0%"></div>
      </div>
    </div>

    <div class="flex items-center gap-2 justify-center">
      <%= form.submit t('video.upload'),
            class: "btn-primary cursor-pointer",
            id: "submit-btn",
            data: { "video-upload-target": "submit" } %>
      <%= link_to t('back'), videos_path, class: "btn-ghost" %>
    </div>
  <% end %>
</div>
