<% video_poll = @video.pending? || @video.processing? %>
<% data_attrs = video_poll ? {
     controller: "video-status",
     "video-status-url-value": video_path(@video, format: :json),
     "video-status-status-completed-value": t('video.status_completed'),
     "video-status-status-processing-value": t('video.status_processing'),
     "video-status-status-failed-value": t('video.status_failed'),
     "video-status-download-label-value": t('video.download'),
     "video-status-error-label-value": t('video.error'),
     "video-status-unknown-error-value": t('video.unknown_error')
   } : {} %>

<%= content_tag :div, class: "max-w-3xl mx-auto", data: data_attrs do %>
  <div class="flex items-start justify-between gap-4 mb-8 flex-wrap">
    <div class="min-w-0 flex-1">
      <div class="text-xs text-text-mute font-mono uppercase tracking-wider mb-2">
        <%= t(:'video.index') %>
      </div>
      <h1 class="text-2xl sm:text-3xl font-medium tracking-tight font-mono break-all">
        <%= @video.original_filename %>
      </h1>
    </div>
    <span class="badge <%= video_status_badge_class(@video.status) %> mt-3"
          data-video-status-target="status">
      <%= t("video.status_#{@video.status}") %>
    </span>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-border rounded overflow-hidden mb-8">
    <div class="bg-surface p-4">
      <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
        <%= t('video.file_size') %>
      </div>
      <div class="font-mono text-sm text-text">
        <%= @video.file_size.present? ? number_to_human_size(@video.file_size) : '—' %>
      </div>
    </div>
    <div class="bg-surface p-4">
      <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
        <%= t('video.duration') %>
      </div>
      <div class="font-mono text-sm text-text">
        <% if @video.duration.present? && @video.duration > 0 %>
          <%= Time.at(@video.duration).utc.strftime("%H:%M:%S") %>
        <% else %>—<% end %>
      </div>
    </div>
    <div class="bg-surface p-4">
      <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
        <%= t('video.recorded_at') %>
      </div>
      <div class="font-mono text-sm text-text">
        <%= @video.recorded_at.present? ? @video.recorded_at.strftime("%-d. %-m. %Y") : '—' %>
      </div>
    </div>
    <div class="bg-surface p-4">
      <div class="text-[10px] uppercase tracking-wider text-text-mute font-mono mb-1">
        <%= t('created_at') %>
      </div>
      <div class="font-mono text-sm text-text">
        <%= @video.created_at.strftime("%-d. %-m. %Y") %>
      </div>
    </div>
  </div>

  <% if @video.failed? && @video.error_message.present? %>
    <div class="flash flash-alert mb-8">
      <span class="text-danger shrink-0 mt-0.5">
        <%= render "shared/icon", name: "x", css: "w-4 h-4" %>
      </span>
      <div class="flex-1">
        <div class="font-medium mb-1"><%= t('video.error') %></div>
        <div class="text-sm font-mono break-all"><%= @video.error_message %></div>
      </div>
    </div>
  <% end %>

  <div class="mb-8" data-video-status-target="actions">
    <% if @video.completed? && @video.stabilized_video.attached? %>
      <%= link_to download_video_path(@video), class: "btn-primary" do %>
        <%= render "shared/icon", name: "download", css: "w-4 h-4" %>
        <%= t('video.download') %>
      <% end %>
    <% elsif video_poll %>
      <div class="panel-inset px-4 py-3 flex items-center gap-3 text-sm text-text-dim">
        <span class="dot bg-warn animate-pulse"></span>
        <span><%= t('video.processing_message') %></span>
      </div>
    <% end %>
  </div>

  <div class="flex items-center gap-2">
    <%= link_to videos_path, class: "btn-ghost" do %>
      <%= render "shared/icon", name: "arrow-left", css: "w-4 h-4" %>
      <%= t(:back) %>
    <% end %>
    <span class="flex-1"></span>
    <%= button_to video_path(@video), method: :delete,
          form: { data: { turbo_confirm: t(:delete_confirm) } },
          data: { confirm: t(:delete_confirm) },
          class: "btn-danger" do %>
      <%= render "shared/icon", name: "trash", css: "w-4 h-4" %>
      <%= t(:delete) %>
    <% end %>
  </div>
<% end %>
