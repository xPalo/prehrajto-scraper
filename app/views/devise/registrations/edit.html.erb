<div class="max-w-md mx-auto py-8">
  <h1 class="text-3xl font-medium tracking-tight mb-8 text-center">
    <%= t(:'header.edit_profile') %>
  </h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-5">
      <div>
        <%= f.label :email, class: "label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="flash flash-notice">
          <%= t(:'devise.waiting_confirmation_for') %>:
          <strong class="ml-1"><%= resource.unconfirmed_email %></strong>
        </div>
      <% end %>

      <div>
        <%= f.label t(:'devise.password'), class: "label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "input",
            placeholder: t(:'devise.password_leave_blank') %>
        <% if @minimum_password_length %>
          <div class="mt-1.5 text-xs text-text-mute font-mono">
            <%= "#{@minimum_password_length} #{t(:'devise.minimum_characters')}" %>
          </div>
        <% end %>
      </div>

      <div>
        <%= f.label t(:'devise.password_confirmation'), class: "label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input" %>
      </div>

      <div>
        <%= f.label t(:'devise.current_password'), class: "label" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "input",
            placeholder: t(:'devise.current_password_confirmation') %>
      </div>
    </div>

    <div class="mt-8">
      <%= f.submit t(:'devise.update_btn'), class: "btn-primary cursor-pointer w-full justify-center" %>
    </div>
  <% end %>

  <div class="mt-10 pt-6 border-t border-border flex items-center justify-between gap-2 flex-wrap">
    <%= link_to t(:back), :back, class: "btn-ghost" %>
    <%= button_to t(:delete), registration_path(resource_name),
          data: { confirm: t(:delete_confirm) },
          form: { data: { turbo_confirm: t(:delete_confirm) } },
          method: :delete,
          class: "btn-danger" %>
  </div>
</div>
