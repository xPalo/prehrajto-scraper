<div class="max-w-sm mx-auto py-8">
  <h1 class="text-3xl font-medium tracking-tight mb-8 text-center">
    <%= t(:'devise.login') %>
  </h1>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="space-y-5">
      <div>
        <%= f.label :email, class: "label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input" %>
      </div>

      <div>
        <%= f.label t(:'devise.password'), class: "label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "input" %>
      </div>
    </div>

    <%= f.hidden_field :remember_me, value: "1" %>

    <div class="mt-8 flex flex-col gap-3">
      <%= f.submit t(:'devise.login_btn'), class: "btn-primary justify-center cursor-pointer w-full" %>
      <%= link_to t(:'devise.dont_have_account_yet'), new_user_registration_path,
          class: "text-sm text-text-dim hover:text-text transition-colors text-center" %>
    </div>
  <% end %>
</div>
