<h1 class="text-3xl font-medium tracking-tight mb-8"><%= I18n.t('user.index') %></h1>

<div data-controller="tabs" class="grid lg:grid-cols-[260px_1fr] gap-6">
  <aside class="panel-inset p-2 lg:max-h-[70vh] overflow-y-auto">
    <ul class="space-y-1">
      <% @users.each_with_index do |user, index| %>
        <li>
          <button type="button"
                  data-tabs-target="tab"
                  data-action="tabs#show"
                  data-key="user-<%= user.id %>"
                  class="w-full flex items-center justify-between gap-2 px-3 py-2 rounded
                         text-left text-sm text-text-dim hover:text-text hover:bg-surface
                         transition-colors <%= 'active text-text bg-surface' if index == 0 %>">
            <span class="truncate font-mono"><%= user.email.split('@').first %></span>
            <span class="text-[10px] font-mono text-text-mute shrink-0">
              <%= user.favs.size %>
            </span>
          </button>
        </li>
      <% end %>
    </ul>
  </aside>

  <div>
    <% @users.each_with_index do |user, index| %>
      <div data-tabs-target="panel"
           data-key="user-<%= user.id %>"
           class="<%= 'hidden' unless index == 0 %>">

        <div class="panel p-6 mb-6">
          <div class="text-xs uppercase tracking-wider text-text-mute font-mono mb-1">
            <%= I18n.t('user.show') %>
          </div>
          <h2 class="text-xl font-mono break-all"><%= user.email %></h2>
          <div class="text-sm text-text-dim mt-2 font-mono">
            <%= I18n.t('user.favs_count') %>: <span class="text-text"><%= user.favs.size %></span>
          </div>
        </div>

        <% if user.favs.any? %>
          <div class="panel mb-6 overflow-hidden">
            <div class="eyebrow eyebrow-left px-4 pt-4 pb-3">
              <span><%= I18n.t('header.favourites') %></span>
            </div>
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-[10px] uppercase tracking-wider text-text-mute font-mono border-y border-border">
                  <th class="px-4 py-2"><%= I18n.t('fav.title') %></th>
                  <th class="px-4 py-2 text-right"><%= I18n.t('created_at') %></th>
                </tr>
              </thead>
              <tbody>
                <% user.favs.each do |fav| %>
                  <tr class="border-b border-border last:border-0 hover:bg-surface-2 transition-colors">
                    <td class="px-4 py-3">
                      <%= link_to fav.title, fav_path(fav),
                          class: "text-text hover:text-accent transition-colors" %>
                    </td>
                    <td class="px-4 py-3 text-right text-text-mute font-mono text-xs">
                      <%= fav.created_at.strftime("%-d. %-m. %Y") %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="panel p-6 mb-6 text-text-mute font-mono text-sm">
            <%= I18n.t('user.no_favs') %>
          </div>
        <% end %>

        <% if user.watchdogs.any? %>
          <div class="panel overflow-hidden">
            <div class="eyebrow eyebrow-left px-4 pt-4 pb-3">
              <span><%= I18n.t('header.watchdogs') %></span>
            </div>
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-[10px] uppercase tracking-wider text-text-mute font-mono border-y border-border">
                  <th class="px-4 py-2"><%= I18n.t('watchdog.from_airport') %></th>
                  <th class="px-4 py-2"><%= I18n.t('watchdog.to_airport') %></th>
                  <th class="px-4 py-2"><%= I18n.t('watchdog.date_watch_from') %></th>
                  <th class="px-4 py-2 text-right"><%= I18n.t('watchdog.max_price') %></th>
                  <th class="px-4 py-2"><%= I18n.t('watchdog.status') %></th>
                  <th class="px-4 py-2"></th>
                </tr>
              </thead>
              <tbody class="font-mono">
                <% user.watchdogs.each do |watchdog| %>
                  <tr class="border-b border-border last:border-0 hover:bg-surface-2 transition-colors">
                    <td class="px-4 py-3"><%= watchdog.from_airport %></td>
                    <td class="px-4 py-3"><%= watchdog.to_airport.presence || watchdog.to_country %></td>
                    <td class="px-4 py-3 text-xs text-text-dim">
                      <% if watchdog.date_watch_from == watchdog.date_watch_to %>
                        <%= l(watchdog.date_watch_from) %>
                      <% else %>
                        <%= l(watchdog.date_watch_from) %> — <%= l(watchdog.date_watch_to) %>
                      <% end %>
                    </td>
                    <td class="px-4 py-3 text-right">
                      <% if watchdog.max_price.present? %>
                        <%= number_to_currency(watchdog.max_price, unit: "€", precision: 0) %>
                      <% else %>
                        <span class="text-text-mute">—</span>
                      <% end %>
                    </td>
                    <td class="px-4 py-3">
                      <span class="<%= watchdog.is_active? ? 'text-accent' : 'text-text-mute' %> text-xs">
                        <%= watchdog.is_active? ? t('watchdog.active') : t('watchdog.inactive') %>
                      </span>
                    </td>
                    <td class="px-4 py-3 text-right">
                      <%= link_to t(:show), watchdog_path(watchdog), class: "btn-link text-xs" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="panel p-6 text-text-mute font-mono text-sm">
            <%= t(:'watchdog.no_data_yet') %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<% if defined?(paginate) && @users.respond_to?(:total_pages) %>
  <%= paginate @users %>
<% end %>
